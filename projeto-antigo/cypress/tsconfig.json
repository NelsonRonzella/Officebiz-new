{
  "compilerOptions": {
    "target": "es5",
    "lib": ["es5", "dom"],
    "types": ["cypress", "node"],
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false
  },
  "include": [
    "**/*.ts",
    "../node_modules/cypress/types"
  ],
  "exclude": [
    "../node_modules/@types/jest",
    "../node_modules/@types/mocha"
  ]
}
