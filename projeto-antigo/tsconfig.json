{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "strict": false,
    "resolveJsonModule": true,
    "types": ["cypress", "node"]
  },
  "include": [
    "cypress.config.ts",
    "cypress/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "vendor"
  ]
}
